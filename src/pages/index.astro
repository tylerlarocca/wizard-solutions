---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import HeroActions from "../components/HeroActions.astro";
import Cards from "../components/Cards.astro";
import Icon from "../components/Icon.astro";
import ClientsStrip from "../components/ClientStrip.astro";
import CTA from "../components/CTA.astro";
import Testimonials from "../components/react/Testimonials";
import { CONTENT, HERO_STATS } from "../lib/content";
---

<BaseLayout
  title="Wizard Solutions"
  description="Modern engineering, automation, content, and growth systems—built like a product."
>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 atmo-hero pointer-events-none"></div>

    <div class="relative">
      <Section
        as="h1"
        size="lg"
        kicker="Wizardry-grade engineering • Armory-level reliability"
        title="Build fast. Look premium."
        subtitle="The Armory for modern business."
        description="We design and ship high-performance websites, custom software, e-commerce, automation, and content—with clean systems and measurable outcomes."
      >
      <HeroActions />

      <div class="mt-10 h-px w-full bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

      <div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-4">
        {HERO_STATS.map((x) => (
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
            <div class="flex items-center gap-2 text-white/80">
              <Icon icon={x.icon} size="sm" />
              <div class="text-sm font-medium">{x.k}</div>
            </div>
            <div class="mt-1 text-sm text-white/60">{x.v}</div>
          </div>
        ))}
      </div>
      </Section>
    </div>
  </section>

  <section id="services" class="relative overflow-hidden">
    <div class="absolute inset-0 atmo-services pointer-events-none"></div>
    <div class="relative">
      <Section
        kicker="What we do"
        title="Services that move the needle"
        description="Pick a single service or bundle them into a full build. Everything is built for performance + ROI."
      >
        <Cards items={CONTENT.services} columns={3} />
      </Section>
    </div>
  </section>

  <section class="relative overflow-hidden">
    <div class="absolute inset-0 atmo-stack pointer-events-none"></div>
    <div class="relative">
      <Section
        kicker="Tools & platforms"
        title="The toolkit"
        description="We choose what fits your business: fast websites, reliable systems, and content that converts."
      >
        <Cards items={CONTENT.stack} columns={4} />
      </Section>
    </div>
  </section>

  <section class="relative overflow-hidden">
    <div class="absolute inset-0 atmo-benefits pointer-events-none"></div>
    <div class="relative">
      <Section
        kicker="How you benefit"
        title="Outcomes, not fluff"
        description="You’ll get a cleaner system, faster site, better conversion, and less operational pain."
      >
        <Cards items={CONTENT.benefits} columns={3} />
      </Section>
    </div>
  </section>

  <section class="relative overflow-hidden">
    <div class="absolute inset-0 atmo-clients pointer-events-none"></div>
    <div class="relative">
      <Section
        kicker="Trusted by"
        title="Current clients & collaborators"
        description="Join the family"
      >
        <ClientsStrip />
      </Section>
    </div>
  </section>

  <section class="relative overflow-hidden">
    <div class="absolute inset-0 atmo-testimonials pointer-events-none"></div>
    <div class="relative">
      <Section
        kicker="Testimonials"
        title="What clients say"
        description="Don't just take my word for it."
      >
        <Testimonials client:load />
      </Section>
    </div>
  </section>

  <CTA />
</BaseLayout>
